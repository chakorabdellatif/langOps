# LangOps local environment. Copy to .env — every value below is a working
# local default; nothing is required to run `docker compose up`.

# ── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_USER=langops
POSTGRES_PASSWORD=langops
POSTGRES_DB=langops

# Used by the backend outside Docker (inside compose the host is `postgres`)
DATABASE_URL=postgresql+asyncpg://langops:langops@localhost:5432/langops

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Backend (langops-api) ──────────────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
# Ingestion limits
INGEST_MAX_PAYLOAD_BYTES=4194304
INGEST_MAX_BATCH_SPANS=2048

# Retention (on by default in compose): delete executions older than N days.
# 0 = keep forever. PRUNE_PAYLOADS_DAYS instead nulls messages/response/state
# while keeping token/cost rollups, so metrics history survives.
RETENTION_DAYS=30
RETENTION_PRUNE_PAYLOADS_DAYS=0

# Optional single-tenant auth. When set, ingest + query require
# `Authorization: Bearer <key>`; the SDK and dashboard proxy send it for you.
# LANGOPS_API_KEY=change-me

# ── Dashboard (baked at build time — NEXT_PUBLIC_*) ────────────────────
# Direct to the backend by default. To hide the API key from the browser when
# auth is on, set this to "/backend" and provide BACKEND_URL + LANGOPS_API_KEY
# to the dashboard's server runtime (the /backend proxy route forwards them).
NEXT_PUBLIC_API_URL=http://localhost:8000
# BACKEND_URL=http://localhost:8000

# ── SDK (read by instrumented apps, not by the stack) ──────────────────
# LANGOPS_ENDPOINT=http://localhost:4317
# LANGOPS_API_KEY=change-me
